GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELL='\033[0;33m'
WHITE='\033[1;97m'
BLUE='\033[1;96m'
grs="\033[96;1m"
redbg="\033[97;41m"
# Getting IP & Hostname
clear
