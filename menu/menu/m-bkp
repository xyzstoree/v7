    rm -rf "$workDir"
    mkdir -p "$workDir"

    backupFile="/root/backup_restore.zip"
    fileUrl="https://api.telegram.org/file/bot${bottoken}/${filePath}"

    # Download
    loading "[ INFO ] Downloading backup from Telegram"
    curl -s -L -o "$backupFile" "$fileUrl"
    [[ -f "$backupFile" ]] && echo -e "${GREEN}[ DONE ]${NC}" || { echo -e "${RED}[ FAILED ] Download error${NC}"; return 1; }

    # Extract
    loading "[ INFO ] Extracting backup"
    unzip_backup_to "$backupFile" "$workDir" "$zipPw"
    [[ $? -eq 0 ]] && echo -e "${GREEN}[ DONE ]${NC}" || { echo -e "${RED}[ FAILED ] Extract error (cek password?)${NC}"; return 1; }

    if [[ ! -d "$workDir/backup" ]]; then
        echo -e "${RED}[ FAILED ] Struktur backup tidak valid (folder backup/ tidak ditemukan)${NC}"
        return 1
    fi

    apply_restore_from_workdir "$workDir"

    # Notifikasi Telegram
    TEXT="<b>в—Үв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв—Ү</b>
<b>   вҷ»пёҸ VPS Restore Completed</b>
<b>в—Үв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв—Ү</b>
рҹ“Ң <b>Date:</b> <code>$(date +"%Y-%m-%d")</code>
рҹҢҚ <b>IP:</b> <code>$(wget -qO- ipinfo.io/ip)</code>
рҹ’Ҙ <b>Domain:</b> <code>${domain}</code>
рҹ‘Ө <b>Name:</b> <code>${nama2}</code>
рҹ—Ӯ <b>File ID:</b> <code>${fileId}</code>
рҹ“Ӯ <b>File Path:</b> <code>${filePath}</code>
<b>в—Үв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв”Ғв—Ү</b>"

    curl -s "https://api.telegram.org/bot${bottoken}/sendMessage" \
        -d "chat_id=${adminid}" \
        --data-urlencode "text=${TEXT}" \
        -d "parse_mode=html" >/dev/null

    # Bersih-bersih
    rm -rf "$workDir" "$backupFile"
    echo -e "${WHITE}вң… RESTORE COMPLETED вҖ” Reboot VPS sekarang${NC}"
    read -n 1 -s -r -p "Press any key to return to menu"
    m_bckp
}

