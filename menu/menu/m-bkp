    local workDir="/root/restore"
    local zipPw
    rm -rf "$workDir"
    mkdir -p "$workDir"

    echo -e "${BLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e " ${BLUE}          рҹ“Ғ RESTORE FILE LANGSUNG рҹ“Ғ           ${NC}"
    echo -e "${BLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"
    echo -e "${BLUE}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${NC}"
    echo -e " ${GREEN}File:${NC} ${backupFile}"
    echo -e " ${YELL}вҖў Ada & valid вҶ’ unzip otomatis${NC}"
    echo -e " ${YELL}вҖў Tidak ada / gagal вҶ’ wget -O lalu unzip${NC}"
    echo -e "${BLUE}в•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җв•җ${NC}"
    read -s -p "$(echo -e "${CYAN}рҹ”’ Password ZIP (Enter jika tidak ada): ${NC}")" zipPw
    echo ""
    echo ""

    local ok=0
    if [[ -f "$backupFile" ]]; then
        echo -ne "[ INFO ] Extract ${backupFile}... "
        if unzip_backup_to "$backupFile" "$workDir" "$zipPw" 2>/dev/null && [[ -d "$workDir/backup" ]]; then
            echo -e "${GREEN}OK${NC}"
            ok=1
        else
            echo -e "${RED}GAGAL${NC}"
            echo -e "${YELL}[ INFO ] Coba unduh dengan wget -O ...${NC}"
            rm -rf "$workDir"
            mkdir -p "$workDir"
        fi
    else
        echo -e "${YELL}[ INFO ] ${backupFile} tidak ditemukan вҖ” masukkan URL unduhan${NC}"
    fi

    if [[ $ok -eq 0 ]]; then
        read -p "$(echo -e "${CYAN}URL file backup (.zip): ${NC}")" dlurl
        if [[ -z "$dlurl" ]]; then
            echo -e "${RED}[ FAILED ] URL kosong${NC}"
            read -n 1 -s -r -p "Press any key to return to menu"
            m_bckp
            return 1
        fi
        echo -ne "[ INFO ] wget -O ${backupFile}... "
        if ! wget -O "$backupFile" "$dlurl"; then
            echo -e "${RED}GAGAL${NC}"
            read -n 1 -s -r -p "Press any key to return to menu"
            m_bckp
            return 1
        fi
        echo -e "${GREEN}OK${NC}"
        echo -ne "[ INFO ] Extract backup... "
        if ! unzip_backup_to "$backupFile" "$workDir" "$zipPw" 2>/dev/null; then
            echo -e "${RED}GAGAL${NC}"
            read -n 1 -s -r -p "Press any key to return to menu"
            m_bckp
            return 1
        fi
        if [[ ! -d "$workDir/backup" ]]; then
            echo -e "${RED}GAGAL (folder backup/ tidak ada)${NC}"
            read -n 1 -s -r -p "Press any key to return to menu"
            m_bckp
            return 1
        fi
        echo -e "${GREEN}OK${NC}"
    fi

    if [[ ! -d "$workDir/backup" ]]; then
        echo -e "${RED}[ FAILED ] Struktur backup tidak valid (folder backup/ tidak ditemukan)${NC}"
        read -n 1 -s -r -p "Press any key to return to menu"
        m_bckp
        return 1
    fi

    apply_restore_from_workdir "$workDir"

    rm -rf "$workDir"
    rm -f "$backupFile"
    echo -e "${WHITE}вң… RESTORE COMPLETED вҖ” Reboot VPS sekarang${NC}"
    read -n 1 -s -r -p "Press any key to return to menu"
    m_bckp
}

autoBackup() {
    # Ambil status & interval
    switch=$(grep -i "switch" /root/.bckupbot | awk '{print $2}')
    interval=$(grep -i "interval" /root/.bckupbot | awk '{print $2}')

    clear
    echo -e "${BLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e " ${BLUE}         вҸ° AUTO BACKUP CONFIGURATION         ${NC}"
    echo -e "${BLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}\n"

    echo -e "${BLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
    echo -e "${BLUE}в”Ӯ${NC} Status AutoBackup : $( [[ "$switch" == "on" ]] && echo -e "${GREEN}[ON]${NC}" || echo -e "${RED}[OFF]${NC}" )"
    echo -e "${BLUE}в”Ӯ${NC} Backup Interval  : ${interval:-Not Set}"
    echo -e "${BLUE}в”Ӯ${NC} [1] Turn ON / Set Interval"
    echo -e "${BLUE}в”Ӯ${NC} [2] Turn OFF Auto Backup"
    echo -e "${BLUE}в”Ӯ${NC} [3] Back To Menu"
    echo -e "${BLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}"

    echo -ne "\nSelect Option [1-3] : "
    read opt
    case "$opt" in
        1)
            clear
            echo -e "${BLUE}в”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ${NC}"
            echo -e "${BLUE}в”Ӯ      вҸұ  Select Interval       в”Ӯ${NC}"
            echo -e "${BLUE}в””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ${NC}\n"

            echo "1) Every 1 Jam"
            echo "2) Every 6 Jam"
            echo "3) Every 12 Jam"
            echo "4) Every 1 Hari"
            echo -ne "\nChoose Interval [1-4]: "
            read choice
            case "$choice" in
                1) interval="1h"; cron="0 * * * *" ;;
                2) interval="6h"; cron="0 */6 * * *" ;;
                3) interval="12h"; cron="0 */12 * * *" ;;
                4) interval="1d"; cron="0 0 * * *" ;;
                *) echo "Invalid choice!"; sleep 1; autoBackup ;;
            esac

            # update .bckupbot
            sed -i "s/^switch.*/switch on/" /root/.bckupbot 2>/dev/null || echo "switch on" >> /root/.bckupbot
            if grep -q "interval" /root/.bckupbot; then
                sed -i "s/^interval.*/interval $interval/" /root/.bckupbot
            else
                echo "interval $interval" >> /root/.bckupbot
            fi

            # buat cron.d file
            cat > /etc/cron.d/bckp_otm << END
SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/sbin:/bin:/usr/sbin:/usr/bin
$cron root bash /usr/local/sbin/backup
END

            chmod 644 /etc/cron.d/bckp_otm
            systemctl restart cron >/dev/null 2>&1
            echo -e "${GREEN}[INFO] AutoBackup is ON with interval $interval${NC}"
            sleep 2
            autoBackup
            ;;
        2)
            sed -i "s/^switch.*/switch off/" /root/.bckupbot
            rm -f /etc/cron.d/bckp_otm
            systemctl restart cron >/dev/null 2>&1
            echo -e "${RED}[INFO] AutoBackup Turned OFF${NC}"
            sleep 2
            autoBackup
            ;;
        3)
            m_bckp
            ;;
        *)
            autoBackup
            ;;
    esac
}

