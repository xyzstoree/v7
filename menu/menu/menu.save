#!/bin/bash
GREEN='\e[36m'
RED='\033[0;31m'
BGBLUE='\e[1;44m'
ORANGE='\033[0;33m'
BLUE='\033[1;36m'
PURPLE='\033[0;35m'
BLUE='\033[0;36m'
BG='\E[44;1;39m'
NC='\033[0;37m'
WHITE='\033[0;37m'
r="\033[1;31m"  #REDTERANG
responden=$(curl -s "http://ip-api.com/json/?fields=country,region,city,timezone,isp")
ISP=$(echo "$responden" | jq -r '.isp')
CITY=$(echo "$responden" | jq -r '.city')
IPVPS=$(curl -s ipv4.icanhazip.com)
domain=$(cat /etc/xray/domain)
RAM=$(free -m | awk 'NR==2 {print $2}')
USAGERAM=$(free -m | awk 'NR==2 {print $3}')
MEMOFREE=$(printf '%-1s' "$(free -m | awk 'NR==2{printf "%.2f%%", $3*100/$2 }')")
LOADCPU=$(printf '%-0.00001s' "$(top -bn1 | awk '/Cpu/ { cpu = "" 100 - $8 "%" }; END { print cpu }')")
MODEL=$(cat /etc/os-release | grep -w PRETTY_NAME | head -n1 | sed 's/=//g' | sed 's/"//g' | sed 's/PRETTY_NAME//g')
CORE=$(printf '%-1s' "$(grep -c cpu[0-9] /proc/stat)")
DATEVPS=$(date +'%d/%m/%Y')
TIMEZONE=$(printf '%(%H:%M:%S)T')
SERONLINE=$(uptime -p | cut -d " " -f 2-10000)
clear
MYIP=$(curl -sS ipv4.icanhazip.com)
echo ""
rm -f /usr/bin/user
username=$(curl -sS https://raw.githubusercontent.com/xyzstoree/izin/main/ip | grep $MYIP | awk '{print $2}')
echo "$username" >/usr/bin/user
rm -f /usr/bin/e
today=`date -d "0 days" +"%Y-%m-%d"`
valid=$(curl -sS https://raw.githubusercontent.com/xyzstoree/izin/main/ip | grep $MYIP | awk '{print $3}')
echo "$valid" >/usr/bin/e
username=$(cat /usr/bin/user)
#oid=$(cat /usr/bin/ver)
exp=$(cat /usr/bin/e)
clear
d1=$(date -d "$valid" +%s)
d2=$(date -d "$today" +%s)
certifacate=$(((d1 - d2) / 86400))
DATE=$(date +'%Y-%m-%d')
datediff() {
d1=$(date -d "$1" +%s)
d2=$(date -d "$2" +%s)
echo -e "$COLOR1 $NC Expiry In   : $(( (d1 - d2) / 86400 )) Days"
}
mai="datediff "$Exp" "$DATE""
Info="${GREEN}Active${NC}"
Error="${RED}Expired${NC}"
if [[ "$certifacate" -le "0" ]]; then
sts="${Error}"
echo -e " ${RED}Masa Aktif Script Kamu Sudah Habis${NC}"
echo -e " ${RED}Silahkan Contact Admin Untuk Perpanjang ${NC}"
echo -e " ${GREEN}Whatsapp = wa.me/6285960592386 ${NC}"
echo -e " ${GREEN}Telegram = @xyztunnn ${NC}"
sleep 3
exit 1
else
sts="${Info}"
fi
echo -e "\e[36mloading...\e[0m"
clear
uptime="$(uptime -p | cut -d " " -f 2-10)"
cpu_usage1="$(ps aux | awk 'BEGIN {sum=0} {sum+=$3}; END {print sum}')"
cpu_usage="$((${cpu_usage1/\.*} / ${coREDiilik:-1}))"
cpu_usage+=" %"
WKT=$(curl -s ipinfo.io/timezone )
DAY=$(date +%A)
DATE=$(date +%m/%d/%Y)
DATE2=$(date -R | cut -d " " -f -5)
IPVPS=$(curl -s ipinfo.io/ip )
cname=$( awk -F: '/model name/ {name=$2} END {print name}' /proc/cpuinfo )
cores=$( awk -F: '/model name/ {core++} END {print core}' /proc/cpuinfo )
freq=$( awk -F: ' /cpu MHz/ {freq=$2} END {print freq}' /proc/cpuinfo )
tram=$( free -m | awk 'NR==2 {print $2}' )
uram=$( free -m | awk 'NR==2 {print $3}' )
fram=$( free -m | awk 'NR==2 {print $4}' )
clear
ssh_service=$(/etc/init.d/ssh status | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
dropbear_service=$(/etc/init.d/dropbear status | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
haproxy_service=$(systemctl status haproxy | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
xray_service=$(systemctl status xray | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
nginx_service=$(systemctl status nginx | grep Active | awk '{print $3}' | cut -d "(" -f2 | cut -d ")" -f1)
clear
if [[ $ssh_service == "running" ]]; then
status_ssh="${GREEN}✓${NC}"
else
status_ssh="${RED}🔴${NC} "
fi
ssh_ws=$( systemctl status ws | grep Active | awk '{print $3}' | sed 's/(//g' | sed 's/)//g' )
if [[ $ssh_ws == "running" ]]; then
status_ws_epro="${GREEN}ON${NC}"
else
status_ws_epro="${RED}🔴${NC} "
fi
if [[ $haproxy_service == "running" ]]; then
status_haproxy="${GREEN}ON  ${NC}"
else
status_haproxy="${RED}🔴${NC} "
fi
if [[ $xray_service == "running" ]]; then
status_xray="${GREEN}ON${NC}"
else
status_xray="${RED}🔴${NC} "
fi
if [[ $nginx_service == "running" ]]; then
status_nginx="${GREEN}ON  ${NC}"
else
status_nginx="${RED}🔴${NC} "
fi
if [[ $dropbear_service == "running" ]]; then
status_dropbear="${GREEN}ON ${NC}"
else
status_dropbear="${RED}🔴${NC} "
fi
vlx=$(grep -c -E "^#& " "/etc/xray/config.json")
let vla=$vlx/2
vmc=$(grep -c -E "^### " "/etc/xray/config.json")
let vma=$vmc/2
ssh1="$(awk -F: '$3 >= 1000 && $1 != "nobody" {print $1}' /etc/passwd | wc -l)"
trx=$(grep -c -E "^#! " "/etc/xray/config.json")
let trb=$trx/2
ssx=$(grep -c -E "^#ss# " "/etc/xray/config.json")
let ssa=$ssx/2
r="\033[1;31m"  #REDTERANG
DROPBEAR_VERSION=$(dropbear -V 2>&1 | grep -oE 'v[0-9.]+')
XRAY_VERSION=$(xray version 2>/dev/null | head -n 1 | awk '{print $2}')
echo -e " "
echo -e "\033[0;34m┌──────────────────────────────────────────┐$NC"
echo -e "\033[0;34m│$NC \033[1;96m            •   XYZ STORE   •           \033[0;34m │$NC"
echo -e "\033[0;34m└──────────────────────────────────────────┘$NC"
echo -e "\033[0;34m┌──────────────────────────────────────────┐$NC"
echo -e "\033[0;34m│$WHITE System OS ${NC}     $WHITE:$NC $MODEL${NC}"
echo -e "\033[0;34m│$WHITE Core System ${NC}   $WHITE:$NC $CORE${NC}"
echo -e "\033[0;34m│$WHITE Server RAM ${NC}    $WHITE:$NC $uram/$RAM MB $NC"
echo -e "\033[0;34m│$WHITE Uptime Server ${NC} $WHITE:$NC $SERONLINE${NC}"
echo -e "\033[0;34m│$WHITE ISP ${NC}           $WHITE:$NC$WHITE $ISP${NC}"
echo -e "\033[0;34m│$WHITE City ${NC}          $WHITE:$NC $CITY${NC}"
echo -e "\033[0;34m│$WHITE Domain ${NC}        $WHITE:$NC$WHITE $domain${NC}"
echo -e "\033[0;34m│$WHITE IP VPS ${NC}        $WHITE:$NC$WHITE $IPVPS${NC}"
echo -e "\033[0;34m│$WHITE Dropbear ${NC}      $WHITE:$NC $DROPBEAR_VERSION${NC}"
echo -e "\033[0;34m│$WHITE Xray ${NC}          $WHITE:$NC v$XRAY_VERSION${NC}"
echo -e "\033[0;34m└──────────────────────────────────────────┘$NC"
echo -e "\033[0;34m┌──────────────────────────────────────────┐\033[0m"
echo -e "\033[0;34m│\033[0m   ${RED}SSH     VMESS     VLESS     TROJAN"
echo -e "\033[0;34m│\033[0m   ${Blue} $ssh1       $vma         $vla         $trb  $NC"
echo -e "\033[0;34m└──────────────────────────────────────────┘\033[0m"
echo -e "\033[0;34m┌──────────────────────────────────────────┐\033[0m"
echo -e "\033[0;34m│ $WHITE NGINX$NC : $status_nginx$WHITE XRAY$NC : $status_xray $WHITE  HAPROXY$NC : $status_haproxy ${NC}\033[0;34m│$NC"
echo -e "\033[0;34m└──────────────────────────────────────────┘\033[0m"
echo -e "\033[0;34m┌──────────────────────────────────────────┐\033[0m"
echo -e "\033[0;34m│ ${NC}${GREEN}[01]•${NC} \033[0mSSH ${NC}      \033[0;34m   │${NC}${GREEN} [10]•${NC} \033[0mBOT PANEL${NC}\033[0;34m     │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[02]•${NC} \033[0mVMESS ${NC}    \033[0;34m   │${NC}${GREEN} [11]•${NC} \033[0mBOT NOTIF${NC}\033[0;34m     │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[03]•${NC} \033[0mVLESS ${NC}    \033[0;34m   │${NC}${GREEN} [12]•${NC} \033[0mSPEEDTEST${NC}\033[0;34m     │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[04]•${NC} \033[0mTROJAN ${NC}   \033[0;34m   │${NC}${GREEN} [13]•${NC} \033[0mDOMAIN${NC}\033[0;34m        │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[05]•${NC} \033[0mBANNER${NC}    \033[0;34m   │${NC}${GREEN} [14]•${NC} \033[0mRESTORE ${NC}\033[0;34m      │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[06]•${NC} \033[0mBACKUP ${NC}    \033[0;34m  │${NC}${GREEN} [15]•${NC} \033[0mCERT SSL ${NC}\033[0;34m     │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[07]•${NC} \033[0mINSTALL UDP ${NC} \033[0;34m│${NC}${GREEN} [16]•${NC} \033[0mALL SERVICE${NC}\033[0;34m   │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[08]•${NC} \033[0mZIVPN${NC}    \033[0;34m    │${NC}${GREEN} [17]•${NC} \033[0mSOCKS5${NC}\033[0;34m        │${NC}"
echo -e "\033[0;34m│ ${NC}${GREEN}[09]•${NC} \033[0mUPDATE SCRIPT${NC}\033[0;34m│${NC}${GREEN} [00]•${NC} \033[0mEXIT${NC}\033[0;34m          │${NC}"
echo -e "\033[0;34m└──────────────────────────────────────────┘\033[0m"
echo -e "\033[0;34m┌──────────────────────────────────────────┐$NC"
echo -e "\033[0;34m│${WHITE} Client  : ${WHITE}$username$NC"
echo -e "\033[0;34m│${WHITE} Script  : ${r}$sts$NC"
echo -e "\033[0;34m│${WHITE} Expired : $WHITE$exp$NC ${r}$certifacate Hari $NC"
echo -e "\033[0;34m└──────────────────────────────────────────┘$NC"
read -p " Select menu : " opt
echo -e ""
case $opt in
1 | 01)
clear
m-sshws
;;
2 | 02)
clear
m-vmess
;;
3 | 03)
clear
m-vless
;;
4 | 04)
clear
m-trojan
;;
5 | 05)
clear
nano /etc/kyt.txt
;;
6 | 06)
clear
m-bkp
;;
7 | 07)
clear
wget https://raw.githubusercontent.com/xyzstoree/v7/main/udp-custom.sh && chmod +x udp-custom.sh && ./udp-custom.sh && rm udp-custom.sh
;;
8 | 08)
clear
[ -x /usr/local/bin/zivpn-manager ] || (apt update -y && wget -q https://raw.githubusercontent.com/xyzstoree/udp-zivpn/main/install.sh -O /usr/local/bin/install.sh && chmod +x /usr/local/bin/install.sh && /usr/local/bin/install.sh); bash /usr/local/bin/zivpn-manager
;;
9 | 09)
clear
wget https://raw.githubusercontent.com/xyzstoree/v7/main/update.sh && chmod +x update.sh && ./update.sh
;;
10 | 10)
clear
add-bot-panel
;;
11)
clear
bot
;;
12)
clear
speedtest
;;
13)
clear
addhost
;;
14)
clear
restore
;;
15)
clear
fixcert
;;
16)
clear
m-services
;;
17)
clear
wget -O socks5.sh https://raw.githubusercontent.com/xyzstoree/socks5/main/socks5.sh && sudo bash socks5.sh
;;
0 | 00)
figlet   XYZ STORE   | lolcat
exit
;;
x)
menu
;;
*)
echo -e ""
menu
;;
esac
exit 0
