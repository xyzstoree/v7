# ====== BOX DRAW HELPERS ======
print_header() { echo -e "${PURPLE}╭──────────────────────────────────────────────╮${NC}"; }
print_footer() { echo -e "${PURPLE}╰──────────────────────────────────────────────╯${NC}"; }
print_line()   { echo -e "${PURPLE}├──────────────────────────────────────────────┤${NC}"; }

# ====== BACKUP / TELEGRAM HELPERS ======
ensure_backup_dir() {
